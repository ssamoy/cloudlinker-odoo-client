<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="cloudlinker_print_wizard_view_form" model="ir.ui.view">
        <field name="name">cloudlinker.print.wizard.view.form</field>
        <field name="model">cloudlinker.print.wizard</field>
        <field name="arch" type="xml">
            <form string="Print via CloudLinker">
                <group>
                    <field name="device_id" options="{'no_create': True}"/>
                    <field name="copies"/>
                    <field name="res_model"     invisible="True"/>
                    <field name="res_id"        invisible="True"/>
                    <field name="document_type" invisible="True"/>
                    <field name="report_ref"    invisible="True"/>
                </group>
                <footer>
                    <button name="action_print" type="object"
                            string="Print" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
