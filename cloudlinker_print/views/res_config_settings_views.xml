<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_cloudlinker" model="ir.ui.view">
        <field name="name">res.config.settings.view.cloudlinker</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="CloudLinker" string="CloudLinker"
                     name="cloudlinker_print"
                     logo="/cloudlinker_print/static/description/icon.png">
                    <block title="Quick Setup"
                           invisible="cloudlinker_organization_id and cloudlinker_api_key">
                        <setting string="Connect your CloudLinker account"
                                 help="Login with your existing account or create a new one to automatically configure the connection.">
                            <div class="mt8">
                                <button name="action_cloudlinker_login_wizard" type="object"
                                        string="Login" icon="fa-sign-in"
                                        class="btn btn-primary me-2"/>
                                <button name="action_cloudlinker_register_wizard" type="object"
                                        string="Create Account" icon="fa-user-plus"
                                        class="btn btn-secondary"/>
                            </div>
                        </setting>
                    </block>
                    <block title="Connection">
                        <setting string="Organization ID"
                                 help="Found in your CloudLinker account settings.">
                            <field name="cloudlinker_organization_id"
                                   class="o_field_highlight w-100"
                                   placeholder="0197df47-871f-72d1-95df-2bfb0c18529a"/>
                        </setting>
                        <setting string="API Key"
                                 help="Your CloudLinker API key.">
                            <field name="cloudlinker_api_key"
                                   class="o_field_highlight w-100"
                                   placeholder="Enter your API key"/>
                        </setting>
                        <setting invisible="not cloudlinker_organization_id and not cloudlinker_api_key">
                            <button name="action_cloudlinker_clear_settings" type="object"
                                    string="Clear Settings" icon="fa-eraser"
                                    class="btn btn-link text-danger"
                                    confirm="This will clear your Organization ID and API Key. Continue?"/>
                        </setting>
                        <setting string="API Base URL"
                                 help="Leave default unless self-hosting.">
                            <field name="cloudlinker_base_url"
                                   placeholder="https://cloudlinker.eu/api"/>
                        </setting>
                    </block>
                    <block title="Printing">
                        <setting string="Auto-print on validation"
                                 help="Automatically send documents to CloudLinker when validated.">
                            <field name="cloudlinker_auto_print"/>
                        </setting>
                    </block>
                    <block title="Client Downloads"
                           invisible="not cloudlinker_organization_id or not cloudlinker_api_key">
                        <setting string="Download the CloudLinker client"
                                 help="Fetch the latest version info and download links.">
                            <div class="mt8">
                                <button name="action_cloudlinker_fetch_downloads" type="object"
                                        string="Check for updates" icon="fa-refresh"
                                        class="btn btn-secondary mb-3"/>
                            </div>
                            <div invisible="not cloudlinker_windows_url" class="mb-2">
                                <i class="fa fa-windows me-1"/>
                                <strong>Windows</strong>
                                <span class="text-muted ms-2">
                                    v<field name="cloudlinker_windows_version" readonly="1" widget="char" class="d-inline"/>
                                </span>
                                <field name="cloudlinker_windows_url" widget="url" readonly="1"
                                       text="Download" class="ms-2 d-inline"/>
                            </div>
                            <div invisible="not cloudlinker_linux_url">
                                <i class="fa fa-linux me-1"/>
                                <strong>Linux</strong>
                                <span class="text-muted ms-2">
                                    v<field name="cloudlinker_linux_version" readonly="1" widget="char" class="d-inline"/>
                                </span>
                                <field name="cloudlinker_linux_url" widget="url" readonly="1"
                                       text="Download" class="ms-2 d-inline"/>
                            </div>
                        </setting>
                    </block>
                    <block title="Actions">
                        <setting>
                            <button name="action_cloudlinker_test_connection" type="object"
                                    string="Test Connection" class="btn btn-secondary me-2"/>
                            <button name="action_cloudlinker_sync_devices" type="object"
                                    string="Sync Clients &amp; Printers" class="btn btn-secondary"/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>
