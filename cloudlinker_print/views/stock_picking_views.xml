<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_picking_form_cloudlinker" model="ir.ui.view">
        <field name="name">stock.picking.form.cloudlinker</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_cloudlinker_print_picking"
                        type="object"
                        string="Print Picking"
                        icon="fa-print"
                        class="btn-secondary"
                        groups="cloudlinker_print.group_cloudlinker_user"/>
                <button name="action_cloudlinker_print_shipping_label"
                        type="object"
                        string="Print Label"
                        icon="fa-tag"
                        class="btn-secondary"
                        groups="cloudlinker_print.group_cloudlinker_user"/>
            </xpath>
        </field>
    </record>
</odoo>
