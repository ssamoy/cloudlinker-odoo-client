<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="cloudlinker_register_wizard_view_form" model="ir.ui.view">
        <field name="name">cloudlinker.register.wizard.view.form</field>
        <field name="model">cloudlinker.register.wizard</field>
        <field name="arch" type="xml">
            <form string="Create CloudLinker Account">
                <group>
                    <field name="firstname"/>
                    <field name="lastname"/>
                    <field name="email" widget="email"/>
                    <field name="password" password="True"/>
                    <field name="company"/>
                    <field name="plan_id"/>
                </group>
                <footer>
                    <button name="action_register" type="object"
                            string="Create Account" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
