<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="cloudlinker_document_rule_view_list" model="ir.ui.view">
        <field name="name">cloudlinker.document.rule.view.list</field>
        <field name="model">cloudlinker.document.rule</field>
        <field name="arch" type="xml">
            <list string="Document Rules" editable="bottom">
                <field name="document_type"/>
                <field name="report_id"/>
                <field name="device_id"/>
                <field name="copies"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="action_cloudlinker_document_rule" model="ir.actions.act_window">
        <field name="name">Document Rules</field>
        <field name="res_model">cloudlinker.document.rule</field>
        <field name="view_mode">list</field>
    </record>
</odoo>
