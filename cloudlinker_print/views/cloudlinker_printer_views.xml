<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================================================================
         CLIENTS
    ================================================================ -->
    <record id="cloudlinker_client_view_list" model="ir.ui.view">
        <field name="name">cloudlinker.client.view.list</field>
        <field name="model">cloudlinker.client</field>
        <field name="arch" type="xml">
            <list string="Clients">
                <field name="hostname"/>
                <field name="ip_address"/>
                <field name="last_seen"/>
                <field name="device_count" string="Printers"/>
            </list>
        </field>
    </record>

    <record id="cloudlinker_client_view_form" model="ir.ui.view">
        <field name="name">cloudlinker.client.view.form</field>
        <field name="model">cloudlinker.client</field>
        <field name="arch" type="xml">
            <form string="CloudLinker Client">
                <sheet>
                    <group>
                        <group>
                            <field name="hostname"/>
                            <field name="cloudlinker_id"/>
                            <field name="ip_address"/>
                        </group>
                        <group>
                            <field name="description"/>
                            <field name="last_seen"/>
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Printers">
                            <field name="device_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="cloudlinker_id"/>
                                    <field name="active"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_cloudlinker_client" model="ir.actions.act_window">
        <field name="name">Clients</field>
        <field name="res_model">cloudlinker.client</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ================================================================
         DEVICES (printers)
    ================================================================ -->
    <record id="cloudlinker_device_view_list" model="ir.ui.view">
        <field name="name">cloudlinker.device.view.list</field>
        <field name="model">cloudlinker.device</field>
        <field name="arch" type="xml">
            <list string="Printers">
                <field name="name"/>
                <field name="client_id"/>
                <field name="cloudlinker_id"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="action_cloudlinker_device" model="ir.actions.act_window">
        <field name="name">Printers</field>
        <field name="res_model">cloudlinker.device</field>
        <field name="view_mode">list</field>
    </record>

</odoo>
