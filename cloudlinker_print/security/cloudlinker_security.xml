<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="group_cloudlinker_user" model="res.groups">
        <field name="name">User</field>
        <field name="category_id" ref="base.module_category_technical"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_cloudlinker_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="category_id" ref="base.module_category_technical"/>
        <field name="implied_ids" eval="[(4, ref('group_cloudlinker_user'))]"/>
        <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>
</odoo>
